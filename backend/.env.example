# PostgreSQL connection string. Create a database (e.g. "taskflow") and run backend/src/sql/schema.sql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow

# --- Firebase Admin credentials ---
# Provide EITHER the base64-encoded service account JSON (recommended for hosts
# like Render/Vercel) ...
FIREBASE_SERVICE_ACCOUNT_B64=

# ... OR a path to the service account JSON file (handy for local dev).
# FIREBASE_SERVICE_ACCOUNT_PATH=../../taskflow-c5c95-firebase-adminsdk-fbsvc-f6aa58f3bf.json

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

PORT=5000
